# .gitattributes
# Enforce LF line endings for all text files in the repository.

# Auto-detect text and normalize to LF.
* text=auto eol=lf

# Explicitly mark common binary file types as binary (no EOL conversion).
*.exe   binary
*.dll   binary
*.sys   binary
*.cat   binary
*.inf   binary
*.png   binary
*.jpg   binary
*.ico   binary
*.zip   binary
*.gz    binary
*.tar   binary
*.7z    binary
*.pdf   binary

# Windows script files — keep LF in repo, convert to CRLF on checkout on Windows.
# (Uncomment if you prefer CRLF for .bat/.ps1 on Windows checkouts.)
# *.bat  text eol=crlf
# *.ps1  text eol=crlf
